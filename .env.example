# Public browser configuration. A publishable key is safe to expose when RLS is enabled.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Optional: auto (default), desktop or mobile. Native iOS/Android builds are always mobile.
VITE_APP_SURFACE=auto

# Server-side equivalents used by TanStack Start.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Keep these values server-side only. Never prefix them with VITE_.
SUPABASE_SECRET_KEY=sb_secret_your_server_key
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=

# Resend inbound email and delivery-status webhooks (server-side only).
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Public legal notice. These values are intentionally visible in the browser.
VITE_LEGAL_OPERATOR_NAME=Bastian Minnich
VITE_LEGAL_FORM=Gewerbe
VITE_LEGAL_REPRESENTATIVE=
VITE_LEGAL_STREET=Bornheimer Str. 33A
VITE_LEGAL_POSTAL_CODE=53111
VITE_LEGAL_CITY=Bonn
VITE_LEGAL_EMAIL=b.minnich@msoftware-ag.de
VITE_LEGAL_PHONE=+49 176 62838195
VITE_LEGAL_REGISTER_COURT=
VITE_LEGAL_REGISTER_NUMBER=
